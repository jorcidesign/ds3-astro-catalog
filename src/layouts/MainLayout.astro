---
import type { SiteData, ProductData, BreadcrumbItem } from '../types';
import Header from '../astro-components/Header.astro';
import Footer from '../astro-components/Footer.astro';
import '../styles/main.scss';

export interface Props {
  title: string;
  description?: string;
  site: SiteData;
  seo?: ProductData['seo'];
  breadcrumb?: ProductData['breadcrumb'];
  currentPath?: string;
}

const { title, description, site, seo, breadcrumb, currentPath } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? title} />
    <title>{title} | {site.siteName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    {seo?.keywords && (
      <meta name="keywords" content={seo.keywords.join(', ')} />
    )}

    {seo?.schemaOrg && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Product',
        ...seo.schemaOrg,
      })} />
    )}

    {breadcrumb && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumb.map((item: BreadcrumbItem, i: number) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: item.label,
          item: `${site.siteUrl}${import.meta.env.BASE_URL}${item.href.replace(/^\//, '')}`,
        })),
      })} />
    )}
  </head>
  <body>
    <Header site={site} currentPath={currentPath} />
    <main class="main-content">
      <slot />
    </main>
    <Footer site={site} />
  </body>
</html>

<style is:global>
  .main-content {
    min-height: 60vh;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1rem;
  }
</style>
