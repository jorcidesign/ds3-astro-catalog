---
import type { SiteData, BreadcrumbItem } from '../types';
import Header from '../astro-components/Header.astro';
import Footer from '../astro-components/Footer.astro';
import BrandNav from '../astro-components/BrandNav.astro';
import BottomBar from '../astro-components/BottomBar.astro';
import TrustStrip from '../astro-components/TrustStrip.astro';
import TrustBar from '../astro-components/TrustBar.astro';
import Toast from '../astro-components/Toast.astro';
import '../styles/main.scss';

export interface Props {
  title: string;
  description?: string;
  site: SiteData;
  showBrandNav?: boolean;
  showTrustStrip?: boolean;
  breadcrumb?: BreadcrumbItem[];
  currentPath?: string;
}

const { title, description, site, showBrandNav = true, showTrustStrip = true, currentPath } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? title} />
    <title>{title} | {site.siteName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header site={site} currentPath={currentPath} />
    {showBrandNav && <BrandNav brands={site.brands} />}
    {showTrustStrip && <TrustStrip />}
    
    <main class="main-content">
      <slot />
    </main>
    
    <TrustBar />
    <Footer site={site} />
    <BottomBar whatsappNumber={site.contact.whatsapp} />
    <Toast />
  </body>
</html>

<style is:global>
  .main-content {
    min-height: 60vh;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--sp-6) var(--gutter);
  }

  @media (max-width: 767px) {
    .main-content {
      padding-bottom: calc(var(--bottom-bar-h) + var(--sp-6));
    }
  }
</style>
