---
import type { SiteData, NavItem, SubNavItem } from '../types';

interface Props {
  site: SiteData;
}

const { site } = Astro.props;
---

<div class="drawer-backdrop" id="drawer-backdrop" aria-hidden="true"></div>

<nav
  class="nav-drawer"
  id="nav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
  aria-hidden="true"
>
  <div class="drawer-head">
    <a href="/" class="drawer-brand" tabindex="-1">
      <span class="drawer-brand__name">DS3</span>
      <span class="drawer-brand__sub">COMUNICACIONES</span>
    </a>
    <button class="drawer-close" id="drawer-close" aria-label="Cerrar menú">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <ul class="drawer-nav" role="list">
    {site.mainNav.map((item: NavItem) => (
      <li class="drawer-nav__item">
        {item.children ? (
          <details class="drawer-group">
            <summary class="drawer-group__summary">
              {item.label}
              <svg class="drawer-chevron" width="16" height="16" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <ul class="drawer-sub" role="list">
              {item.children.map((child: SubNavItem) => (
                <li>
                  <a href={child.href} class="drawer-sub__link">{child.label}</a>
                </li>
              ))}
            </ul>
          </details>
        ) : (
          <a href={item.href} class="drawer-nav__link">{item.label}</a>
        )}
      </li>
    ))}
  </ul>

  <div class="drawer-contact">
    <p class="drawer-contact__label">Contáctanos</p>
    {site.contact.mobile.map((m: string) => (
      <a href={`tel:${m.replace(/[\s()\-]/g, '')}`} class="drawer-contact__phone">{m}</a>
    ))}
    <a
      href={`https://wa.me/${site.contact.whatsapp}`}
      class="drawer-contact__wa"
      target="_blank"
      rel="noopener"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.122 1.529 5.86L0 24l6.335-1.51A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.37l-.36-.213-3.76.896.953-3.651-.235-.374A9.818 9.818 0 012.182 12c0-5.419 4.399-9.818 9.818-9.818 5.42 0 9.818 4.399 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
      </svg>
      WhatsApp
    </a>
  </div>
</nav>

<script>
(function () {
  const backdrop = document.getElementById('drawer-backdrop');
  const drawer   = document.getElementById('nav-drawer');
  const closeBtn = document.getElementById('drawer-close');
  const menuBtn  = document.getElementById('menu-btn');

  function openDrawer() {
    drawer?.removeAttribute('aria-hidden');
    drawer?.classList.add('is-open');
    backdrop?.removeAttribute('aria-hidden');
    backdrop?.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
    menuBtn?.setAttribute('aria-expanded', 'true');
    setTimeout(() => (closeBtn as HTMLElement | null)?.focus(), 50);
  }

  function closeDrawer() {
    drawer?.setAttribute('aria-hidden', 'true');
    drawer?.classList.remove('is-open');
    backdrop?.setAttribute('aria-hidden', 'true');
    backdrop?.classList.remove('is-visible');
    document.body.style.overflow = '';
    menuBtn?.setAttribute('aria-expanded', 'false');
    (menuBtn as HTMLElement | null)?.focus();
  }

  menuBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeDrawer();
  });

  drawer?.querySelectorAll('.drawer-sub__link, .drawer-nav__link').forEach((link) => {
    link.addEventListener('click', closeDrawer);
  });
}());
</script>

<style>
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: calc(var(--z-sticky) + 5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .drawer-backdrop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-drawer {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 86vw);
    background: var(--surface-card);
    z-index: calc(var(--z-sticky) + 10);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 450ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    overscroll-behavior: contain;
    box-shadow: var(--shadow-xl);
  }
  .nav-drawer.is-open {
    transform: translateX(0);
  }

  /* ── Head ── */
  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-4) var(--sp-5);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .drawer-brand {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    gap: 1px;
  }
  .drawer-brand__name {
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--text-lg);
    color: #0d3d6b;
    line-height: 1;
  }
  .drawer-brand__sub {
    font-size: 0.52rem;
    font-weight: var(--fw-semibold);
    color: var(--text-mid);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
  }

  .drawer-close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--text-mid);
    transition: var(--t-color);
    flex-shrink: 0;
  }
  .drawer-close:hover {
    background: var(--clr-n-100);
    color: var(--text-hi);
  }

  /* ── Nav list ── */
  .drawer-nav {
    flex: 1;
    padding: var(--sp-2) 0;
    list-style: none;
  }

  .drawer-nav__item {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms cubic-bezier(0.16, 1, 0.3, 1), transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-drawer.is-open .drawer-nav__item {
    opacity: 1;
    transform: translateY(0);
  }

  /* Efecto cascada (stagger) para los ítems del menú */
  .nav-drawer.is-open .drawer-nav__item:nth-child(1) { transition-delay: 40ms; }
  .nav-drawer.is-open .drawer-nav__item:nth-child(2) { transition-delay: 80ms; }
  .nav-drawer.is-open .drawer-nav__item:nth-child(3) { transition-delay: 120ms; }
  .nav-drawer.is-open .drawer-nav__item:nth-child(4) { transition-delay: 160ms; }
  .nav-drawer.is-open .drawer-nav__item:nth-child(5) { transition-delay: 200ms; }
  .nav-drawer.is-open .drawer-nav__item:nth-child(6) { transition-delay: 240ms; }
  .nav-drawer.is-open .drawer-nav__item:nth-child(7) { transition-delay: 280ms; }

  .drawer-nav__link {
    display: block;
    padding: var(--sp-3) var(--sp-5);
    font-size: var(--text-base);
    font-weight: var(--fw-medium);
    color: var(--text-hi);
    text-decoration: none;
    transition: var(--t-color);
  }
  .drawer-nav__link:hover {
    background: var(--clr-n-50);
    color: var(--text-brand);
  }

  /* ── Accordion group ── */
  .drawer-group {
    border: none;
  }
  .drawer-group__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-5);
    font-size: var(--text-base);
    font-weight: var(--fw-medium);
    color: var(--text-hi);
    cursor: pointer;
    list-style: none;
    transition: var(--t-color);
    user-select: none;
  }
  .drawer-group__summary::-webkit-details-marker { display: none; }
  .drawer-group__summary::marker { display: none; }
  .drawer-group__summary:hover {
    background: var(--clr-n-50);
    color: var(--text-brand);
  }

  .drawer-chevron {
    color: var(--clr-n-400);
    flex-shrink: 0;
    transition: transform var(--dur-200) var(--ease-in-out);
  }
  .drawer-group[open] .drawer-chevron {
    transform: rotate(180deg);
  }

  .drawer-sub {
    list-style: none;
    background: var(--clr-n-50);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .drawer-sub__link {
    display: block;
    padding: 0.6rem var(--sp-5) 0.6rem calc(var(--sp-5) + var(--sp-3));
    font-size: var(--text-sm);
    color: var(--text-mid);
    text-decoration: none;
    transition: var(--t-color);
  }
  .drawer-sub__link:hover {
    color: var(--text-brand);
    background: var(--clr-p-50);
  }

  /* ── Contact footer ── */
  .drawer-contact {
    padding: var(--sp-5);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 500ms cubic-bezier(0.16, 1, 0.3, 1) 180ms, transform 500ms cubic-bezier(0.16, 1, 0.3, 1) 180ms;
  }

  .nav-drawer.is-open .drawer-contact {
    opacity: 1;
    transform: translateY(0);
  }
  .drawer-contact__label {
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    color: var(--text-low);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    margin-bottom: var(--sp-1);
  }
  .drawer-contact__phone {
    font-size: var(--text-sm);
    color: var(--text-mid);
    text-decoration: none;
    transition: color var(--dur-150) var(--ease-out);
  }
  .drawer-contact__phone:hover { color: var(--text-brand); }

  .drawer-contact__wa {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: var(--clr-a-500);
    color: #fff;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    width: fit-content;
    transition: background var(--dur-150) var(--ease-out);
  }
  .drawer-contact__wa:hover {
    background: var(--clr-a-600);
    color: #fff;
  }

  /* Desktop: hide entirely */
  @media (min-width: 768px) {
    .nav-drawer,
    .drawer-backdrop {
      display: none !important;
    }
  }
</style>
