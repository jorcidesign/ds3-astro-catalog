---
interface TrustBadge {
  icon: string;
  label: string;
  text: string;
}

const badges: TrustBadge[] = [
  {
    icon: 'shipping',
    label: 'Envío gratis',
    text: 'A partir de S/ 500 en toda la sierra, costa y selva del Perú'
  },
  {
    icon: 'guarantee',
    label: 'Garantía total',
    text: 'Todos los productos cuentan con garantía oficial del fabricante'
  },
  {
    icon: 'support',
    label: 'Soporte técnico',
    text: 'Asesoría especializada para tus proyectos de networking'
  }
];
---

<div class="container">
  <div class="trust-bar">
    {badges.map((badge) => (
      <div class="trust-badge">
        {badge.icon === 'shipping' && (
          <svg class="trust-badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        )}
        {badge.icon === 'guarantee' && (
          <svg class="trust-badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
        )}
        {badge.icon === 'support' && (
          <svg class="trust-badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        )}
        <span class="trust-badge-label">{badge.label}</span>
        <span class="trust-badge-text">{badge.text}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .trust-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin: var(--sp-8) 0;
  }

  .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-2);
    padding: var(--sp-5);
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .trust-badge-icon {
    width: 48px;
    height: 48px;
    color: var(--clr-p-500);
  }

  .trust-badge-label {
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-hi);
  }

  .trust-badge-text {
    font-size: var(--text-xs);
    color: var(--text-mid);
    line-height: var(--lh-relaxed);
  }

  @media (max-width: 640px) {
    .trust-bar {
      grid-template-columns: 1fr;
    }
  }
</style>
