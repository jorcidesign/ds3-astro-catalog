---
/* Slot names must be static strings in Astro.
   This component exposes 4 fixed slots: tab-desc, tab-specs, tab-apps, tab-faq.
   Hide a tab by leaving its slot empty — the button will still show but can be
   suppressed via the `hideTabs` prop if needed in the future. */

interface Props {
  labels?: {
    desc?: string;
    specs?: string;
    apps?: string;
    faq?: string;
  };
}

const { labels = {} } = Astro.props;

const tabDef = [
  { id: 'desc',  label: labels.desc  ?? 'Descripción'      },
  { id: 'specs', label: labels.specs ?? 'Especificaciones' },
  { id: 'apps',  label: labels.apps  ?? 'Aplicaciones'     },
  { id: 'faq',   label: labels.faq   ?? 'FAQ'              },
] as const;
---

<div class="tabs-wrap">
  <div class="tabs" role="tablist" aria-label="Secciones del producto">
    {tabDef.map((tab, i) => (
      <button
        class={`tab-btn${i === 0 ? ' is-active' : ''}`}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`panel-${tab.id}`}
        id={`tab-${tab.id}`}
      >
        {tab.label}
      </button>
    ))}
  </div>

  <div class="tab-panel is-active" id="panel-desc" role="tabpanel" aria-labelledby="tab-desc" tabindex="0">
    <slot name="tab-desc" />
  </div>
  <div class="tab-panel" id="panel-specs" role="tabpanel" aria-labelledby="tab-specs" tabindex="-1">
    <slot name="tab-specs" />
  </div>
  <div class="tab-panel" id="panel-apps" role="tabpanel" aria-labelledby="tab-apps" tabindex="-1">
    <slot name="tab-apps" />
  </div>
  <div class="tab-panel" id="panel-faq" role="tabpanel" aria-labelledby="tab-faq" tabindex="-1">
    <slot name="tab-faq" />
  </div>
</div>

<script>
(function () {
  document.querySelectorAll('.tabs-wrap').forEach((wrap) => {
    const btns   = wrap.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = wrap.querySelectorAll<HTMLElement>('.tab-panel');

    function activate(idx: number) {
      btns.forEach((b, i) => {
        const on = i === idx;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      panels.forEach((p, i) => {
        const on = i === idx;
        p.classList.toggle('is-active', on);
        p.setAttribute('tabindex', on ? '0' : '-1');
      });
    }

    btns.forEach((btn, i) => {
      btn.addEventListener('click', () => activate(i));
      btn.addEventListener('keydown', (e) => {
        const list = [...btns];
        if (e.key === 'ArrowRight') { e.preventDefault(); const n = (i + 1) % list.length; list[n].focus(); activate(n); }
        if (e.key === 'ArrowLeft')  { e.preventDefault(); const n = (i - 1 + list.length) % list.length; list[n].focus(); activate(n); }
        if (e.key === 'Home')  { e.preventDefault(); list[0].focus(); activate(0); }
        if (e.key === 'End')   { e.preventDefault(); list[list.length - 1].focus(); activate(list.length - 1); }
      });
    });
  });
}());
</script>

<style>
  .tabs-wrap { /* wrap container */ }

  .tabs {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    border-bottom: 2px solid var(--border);
  }
  .tabs::-webkit-scrollbar { display: none; }

  .tab-btn {
    flex: 0 0 auto;
    padding: var(--sp-3) var(--sp-5);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    color: var(--text-mid);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--dur-150) var(--ease-out), border-color var(--dur-150) var(--ease-out);
    -webkit-tap-highlight-color: transparent;
  }
  .tab-btn:hover { color: var(--text-brand); }
  .tab-btn.is-active {
    color: var(--text-brand);
    border-bottom-color: var(--clr-p-500);
    font-weight: var(--fw-semibold);
  }
  .tab-btn:focus-visible { outline: none; color: var(--text-brand); }

  .tab-panel {
    display: none;
    padding-top: var(--sp-6);
  }
  .tab-panel.is-active { display: block; }
  .tab-panel:focus { outline: none; }
</style>
