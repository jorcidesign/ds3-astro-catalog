---
import type { KeyFeature } from '../types';

interface Props {
  features: KeyFeature[];
}

const { features } = Astro.props;
---

<section class="features-strip" aria-label="Características clave">
  <div class="features-grid">
    {features.map((f: KeyFeature) => (
      <div class="feature-item">
        <svg class="feature-icon" aria-hidden="true">
          <use href={`/icons.svg#${f.icon}`} />
        </svg>
        <div class="feature-text">
          <span class="feature-label">{f.label}</span>
          <span class="feature-value">{f.value}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .features-strip {
    padding: var(--sp-6) 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--sp-4);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .feature-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    color: var(--clr-p-500);
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .feature-label {
    font-size: var(--text-xs);
    color: var(--text-low);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    font-weight: var(--fw-medium);
  }

  .feature-value {
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-hi);
  }
</style>
