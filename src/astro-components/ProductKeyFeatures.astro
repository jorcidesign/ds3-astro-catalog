---
import type { KeyFeature } from '../types';

interface Props {
  features: KeyFeature[];
}

const { features } = Astro.props;

/* Map icon name → SVG path(s) for inline rendering */
const iconPaths: Record<string, string> = {
  cable:         '<path d="M4 12h16M4 6h16M4 18h16"/>',
  'shield-check': '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
  ruler:         '<path d="M2 20h20M6 20V4l4 4 4-4 4 4v16"/>',
  package:       '<path d="m16.5 9.4-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/>',
  zap:           '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  'check-circle':'<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
  ruler2:        '<rect x="2" y="7" width="20" height="10" rx="2"/><path d="M8 7V5m4 2V5m4 2V5"/>',
  clock:         '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
};
---

<div class="features-strip" aria-label="Características principales">
  {features.map((f: KeyFeature) => (
    <div class="feature-item">
      <svg
        class="feature-item__icon"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={iconPaths[f.icon] ?? iconPaths['check-circle']}
      />
      <span class="feature-item__value">{f.value}</span>
      <span class="feature-item__label">{f.label}</span>
    </div>
  ))}
</div>

<style>
  .features-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-1);
    padding: var(--sp-3) var(--sp-2);
    background: #fff;
    transition: background var(--dur-150) var(--ease-out);
    min-width: 0;
  }
  .feature-item:hover {
    background: var(--clr-p-50);
  }

  .feature-item__icon {
    color: var(--clr-p-500);
    margin-bottom: var(--sp-0-5);
    flex-shrink: 0;
  }

  .feature-item__value {
    font-size: var(--text-xs);
    font-weight: var(--fw-bold);
    color: var(--text-hi);
    line-height: var(--lh-tight);
    word-break: break-word;
  }

  .feature-item__label {
    font-size: 0.65rem;
    color: var(--text-mid);
    line-height: var(--lh-snug);
    word-break: break-word;
  }

  @media (max-width: 480px) {
    .features-strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 480px) {
    .feature-item__value { font-size: var(--text-sm); }
    .feature-item__label { font-size: var(--text-xs); }
  }
</style>
