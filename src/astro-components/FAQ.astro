---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title } = Astro.props;
---

{title && <h2 class="faq-title">{title}</h2>}

<div class="faq">
  {items.map((item: FAQItem) => (
    <details class="faq-item">
      <summary class="faq-summary">
        <span>{item.question}</span>
        <svg
          class="faq-chevron"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </summary>
      <div class="faq-body">
        <Fragment set:html={item.answer} />
      </div>
    </details>
  ))}
</div>

<style>
  .faq-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--fw-bold);
    color: var(--text-hi);
    margin-bottom: var(--sp-6);
  }

  .faq {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 800px;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--dur-150) var(--ease-out);
  }
  .faq-item:hover {
    border-color: var(--clr-p-300, #8fcce4);
  }
  .faq-item[open] {
    border-color: var(--clr-p-300, #8fcce4);
    box-shadow: var(--shadow-sm);
  }

  .faq-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    cursor: pointer;
    font-size: var(--text-base);
    font-weight: var(--fw-semibold);
    color: var(--text-hi);
    transition: color var(--dur-150) var(--ease-out);
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::marker { display: none; }
  .faq-summary:hover {
    color: var(--text-brand);
  }

  .faq-chevron {
    color: var(--clr-p-500);
    flex-shrink: 0;
    transition: transform var(--dur-200) var(--ease-in-out);
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-body {
    padding: 0 var(--sp-5) var(--sp-5);
    font-size: var(--text-sm);
    color: var(--text-mid);
    line-height: var(--lh-relaxed);
  }

  :global(.faq-body strong) {
    color: var(--text-hi);
    font-weight: var(--fw-semibold);
  }
</style>
