---
import type { SiteData, BrandEntry } from '../types';

interface Props {
  site: SiteData;
}

const { site } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <img src={site.logo} alt={site.siteName} class="footer-logo" />
      </a>
      <p class="footer-tagline">{site.tagline}</p>
      <a
        href={`https://wa.me/${site.contact.whatsapp}`}
        class="whatsapp-btn"
        target="_blank"
        rel="noopener"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <div class="footer-contact">
      <h3 class="footer-title">Contacto</h3>
      <ul class="footer-list">
        {site.contact.phone.map((p: string) => (
          <li><a href={`tel:${p.replace(/\D/g, '')}`}>{p}</a></li>
        ))}
        {site.contact.mobile.map((m: string) => (
          <li><a href={`tel:${m.replace(/\D/g, '')}`}>{m}</a></li>
        ))}
        {site.contact.email.map((e: string) => (
          <li><a href={`mailto:${e}`}>{e}</a></li>
        ))}
      </ul>
      <div class="footer-hours">
        <span class="footer-hours-label">Horario:</span>
        <p>{site.contact.hours.weekdays}</p>
        <p>{site.contact.hours.saturday}</p>
      </div>
    </div>

    <div class="footer-links">
      <h3 class="footer-title">Marcas</h3>
      <div class="brand-row">
        {site.brands.map((brand: BrandEntry) => (
          <a href={brand.href} title={brand.name}>
            <img src={brand.logo} alt={brand.name} loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {year} {site.siteName}. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--clr-n-900);
    color: var(--text-inverse);
    padding: var(--sp-12) 0 var(--sp-4);
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--sp-8);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer-logo-link {
    display: inline-flex;
  }

  .footer-logo {
    height: 40px;
    width: auto;
    filter: brightness(0.9);
  }

  .footer-tagline {
    color: var(--clr-n-400);
    font-size: var(--text-sm);
    line-height: var(--lh-relaxed);
    max-width: 320px;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: var(--clr-a-500);
    color: var(--text-inverse);
    text-decoration: none;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    transition: var(--t-color);
    width: fit-content;
  }

  .whatsapp-btn:hover {
    background: var(--clr-a-600);
  }

  .footer-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-inverse);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    margin-bottom: var(--sp-4);
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .footer-list a {
    color: var(--clr-n-400);
    font-size: var(--text-sm);
    display: block;
    padding: var(--sp-1) 0;
    transition: var(--t-color);
    text-decoration: none;
  }

  .footer-list a:hover {
    color: var(--text-inverse);
  }

  .footer-hours {
    margin-top: var(--sp-4);
    color: var(--clr-n-400);
    font-size: var(--text-sm);
  }

  .footer-hours-label {
    font-weight: var(--fw-semibold);
    color: var(--clr-n-300);
  }

  .footer-hours p {
    margin: var(--sp-1) 0 0;
  }

  .brand-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .brand-row a {
    display: flex;
    align-items: center;
    padding: var(--sp-1) var(--sp-2);
    background: var(--clr-n-800);
    border-radius: var(--radius-sm);
    transition: var(--t-color);
    text-decoration: none;
  }

  .brand-row a:hover {
    background: var(--clr-n-700);
  }

  .brand-row img {
    height: 20px;
    width: auto;
    filter: brightness(0.9);
  }

  .footer-bottom {
    max-width: var(--container-max);
    margin: var(--sp-8) auto 0;
    padding: var(--sp-4) var(--gutter) 0;
    border-top: 1px solid var(--clr-n-800);
    text-align: center;
    font-size: var(--text-xs);
    color: var(--clr-n-500);
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer-tagline {
      max-width: 100%;
    }
  }
</style>
