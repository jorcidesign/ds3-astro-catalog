---
import type { ProductData, ProductImage } from '../types';

interface Props {
  product: ProductData;
}

const { product } = Astro.props;

const mainImage: ProductImage | undefined = product.images.find((img: ProductImage) => img.role === 'main');
const brandSlug = product.brand.toLowerCase();
---

<article class="product-card">
  <a href={`/productos/${brandSlug}/${product.slug.split('/').pop()}`} class="card-link">
    <div class="card-image">
      {mainImage && <img src={mainImage.src} alt={mainImage.alt} loading="lazy" />}
      {product.isNew && <span class="badge badge--new">Nuevo</span>}
    </div>
    <div class="card-body">
      <span class="card-brand">{product.brand}</span>
      <h3 class="card-title">{product.name}</h3>
      <p class="card-desc">{product.shortDescription}</p>
      <div class="card-footer">
        <span class="card-price">
          {product.price.amount > 0
            ? `$${product.price.amount.toFixed(2)}`
            : 'Consultar precio'}
        </span>
        <span class="card-cta">Ver producto →</span>
      </div>
    </div>
  </a>
</article>

<style>
  .product-card {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: var(--t-shadow), var(--t-transform);
  }

  .product-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--clr-n-50);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--sp-4);
    transition: var(--t-transform);
  }

  .product-card:hover .card-image img {
    transform: scale(1.04);
  }

  .badge {
    position: absolute;
    top: var(--sp-2);
    left: var(--sp-2);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .badge--new {
    background: var(--clr-p-500);
    color: var(--text-inverse);
  }

  .card-body {
    padding: var(--sp-4);
  }

  .card-brand {
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    color: var(--text-brand);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .card-title {
    font-size: var(--text-md);
    font-weight: var(--fw-semibold);
    color: var(--text-hi);
    margin: var(--sp-1) 0 var(--sp-2);
    line-height: var(--lh-snug);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-mid);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: var(--lh-relaxed);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--sp-4);
    padding-top: var(--sp-3);
    border-top: 1px solid var(--border);
  }

  .card-price {
    font-size: var(--text-lg);
    font-weight: var(--fw-bold);
    color: var(--clr-success-text);
  }

  .card-cta {
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-link);
  }
</style>
