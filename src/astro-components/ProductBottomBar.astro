---
interface Props {
  productName: string;
  sku: string;
  whatsapp: string;
  orderUrl?: string;
}

const {
  productName,
  sku,
  whatsapp,
  orderUrl = 'https://www.ds3comunicaciones.com/pedido.html',
} = Astro.props;
---

<div
  class="product-bottom-bar"
  role="navigation"
  aria-label="Acciones de compra"
  data-whatsapp={whatsapp}
  data-product-name={productName}
  data-sku={sku}
>
  <!-- Comprar -->
  <a
    href={orderUrl}
    class="pbb-btn pbb-btn--primary"
    target="_blank"
    rel="noopener"
    aria-label={`Comprar ${productName}`}
  >
    <svg class="pbb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="21" r="1"/>
      <circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    Comprar
  </a>

  <!-- WhatsApp -->
  <a
    href={`https://wa.me/${whatsapp}?text=${encodeURIComponent(`Hola, quiero cotizar ${productName} (SKU: ${sku}). Por favor indicarme precio y disponibilidad.`)}`}
    class="pbb-btn pbb-btn--wa"
    target="_blank"
    rel="noopener"
    aria-label="Contactar por WhatsApp"
  >
    <svg class="pbb-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.122 1.529 5.86L0 24l6.335-1.51A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.003-1.37l-.36-.213-3.76.896.953-3.651-.235-.374A9.818 9.818 0 012.182 12c0-5.419 4.399-9.818 9.818-9.818 5.42 0 9.818 4.399 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
    </svg>
    WhatsApp
  </a>

  <!-- Cotizar -->
  <button class="pbb-btn pbb-btn--outline" id="pbb-cotizar" aria-label="Solicitar cotización">
    <svg class="pbb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14,2 14,8 20,8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
    </svg>
    Cotizar
  </button>
</div>

<script>
(function () {
  const bar = document.querySelector<HTMLElement>('.product-bottom-bar');
  const cotizarBtn = document.getElementById('pbb-cotizar');
  if (!bar || !cotizarBtn) return;

  cotizarBtn.addEventListener('click', () => {
    const wa   = bar.dataset.whatsapp || '';
    const name = bar.dataset.productName || '';
    const sku  = bar.dataset.sku || '';
    const qty  = (document.getElementById('qty-input') as HTMLInputElement | null)?.value || '1';

    const msg = encodeURIComponent(
      `Hola, quiero cotizar ${qty} unidad(es) de ${name} (SKU: ${sku}). Por favor indicarme precio y disponibilidad.`
    );
    window.open(`https://wa.me/${wa}?text=${msg}`, '_blank', 'noopener,noreferrer');
  });
}());
</script>

<style>
  .product-bottom-bar {
    display: none; /* shown only on mobile */
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: calc(56px + var(--safe-bottom));
    padding-bottom: var(--safe-bottom);
    z-index: var(--z-sticky);
    box-shadow: 0 -1px 0 var(--border), 0 -4px 16px -4px rgba(0,0,0,.10);
  }

  @media (max-width: 767px) {
    .product-bottom-bar {
      display: flex;
      align-items: stretch;
    }
  }

  .pbb-btn {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: none;
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    font-family: inherit;
    text-decoration: none;
    border-radius: 0;
    padding-inline: var(--sp-2);
    -webkit-tap-highlight-color: transparent;
    transition: background var(--dur-150) var(--ease-out);
  }

  .pbb-btn--primary {
    background: var(--clr-p-500);
    color: #fff;
  }
  .pbb-btn--primary:active {
    background: var(--clr-p-700);
  }

  .pbb-btn--wa {
    background: #25d366;
    color: #fff;
  }
  .pbb-btn--wa:active {
    background: #1db954;
  }

  .pbb-btn--outline {
    background: #fff;
    color: var(--clr-p-500);
    border-left: 1px solid var(--border);
  }
  .pbb-btn--outline:active {
    background: var(--clr-p-50);
  }

  .pbb-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>
