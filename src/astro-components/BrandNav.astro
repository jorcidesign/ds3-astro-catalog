---
import type { BrandEntry } from '../types';

interface Props {
  brands: BrandEntry[];
}

const { brands } = Astro.props;
---

<nav class="brand-nav" aria-label="Navegación de marcas">
  <div class="brand-nav-inner">
    {brands.map((brand: BrandEntry) => (
      <a href={brand.href} class="brand-logo-link" title={brand.name}>
        <img src={brand.logo} alt={brand.name} loading="lazy" />
      </a>
    ))}
  </div>
</nav>

<style>
  .brand-nav {
    background: var(--surface-card);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .brand-nav-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--sp-3) var(--gutter);
    display: flex;
    gap: var(--sp-4);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    align-items: center;
  }

  .brand-nav-inner::-webkit-scrollbar {
    display: none;
  }

  .brand-logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    transition: var(--t-color);
  }

  .brand-logo-link:hover {
    background: var(--clr-n-100);
  }

  .brand-logo-link img {
    height: 28px;
    width: auto;
    object-fit: contain;
  }
</style>
