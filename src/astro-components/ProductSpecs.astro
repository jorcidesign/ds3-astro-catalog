---
import type { SpecRow } from '../types';

interface Props {
  specTable: SpecRow[];
}

const { specTable } = Astro.props;
---

<section class="spec-table" aria-label="Especificaciones técnicas">
  <div class="spec-table-inner">
    {specTable.map((row: SpecRow, i: number) => (
      <div class={`spec-row ${i % 2 === 0 ? 'even' : ''}`}>
        <span class="spec-label">{row.label}</span>
        <span class="spec-value">{row.value}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .spec-table {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .spec-table-inner {
    display: grid;
  }

  .spec-row {
    display: grid;
    grid-template-columns: 40% 1fr;
    gap: var(--sp-4);
    padding: var(--sp-3) var(--sp-4);
    border-bottom: 1px solid var(--border);
  }

  .spec-row:last-child {
    border-bottom: none;
  }

  .spec-row.even {
    background: var(--clr-n-50);
  }

  .spec-label {
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-mid);
  }

  .spec-value {
    font-size: var(--text-sm);
    color: var(--text-hi);
  }

  @media (max-width: 480px) {
    .spec-row {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>
