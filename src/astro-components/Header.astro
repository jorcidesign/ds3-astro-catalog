---
import type { SiteData } from '../types';

interface Props {
  site: SiteData;
  currentPath?: string;
}

const { site } = Astro.props;
---

<header class="site-header" role="banner">
  <div class="header-inner">

    <!-- Izquierda: hamburger (mobile) -->
    <div class="header-left">
      <button
        class="header-btn header-hamburger"
        id="menu-btn"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Centro (mobile) / Izquierda (desktop): Logo -->
    <a href="/" class="site-logo" aria-label={`${site.siteName} — Inicio`}>
      <img
        src={site.logo}
        alt={site.siteName}
        class="site-logo__img"
        referrerpolicy="no-referrer"
      />
    </a>

    <!-- Desktop only: barra de contacto -->
    <div class="header-contact" aria-label="Información de contacto">
      <span>{site.contact.phone[0]}</span>
      <span class="contact-sep" aria-hidden="true">·</span>
      <strong>{site.contact.mobile[0]}</strong>
      <span class="contact-sep" aria-hidden="true">·</span>
      <span class="contact-hours">{site.contact.hours.weekdays}</span>
    </div>

    <!-- Derecha: search -->
    <div class="header-actions">
      <button class="header-btn" id="search-btn" aria-label="Buscar productos">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </div>

  </div>
</header>


<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: #fff;
    border-bottom: 1px solid var(--border);
    height: 56px;
  }

  .header-inner {
    display: grid;
    grid-template-columns: 44px 1fr 44px;
    align-items: center;
    height: 100%;
    padding-inline: var(--sp-3);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* ── Left ── */
  .header-left {
    display: flex;
    align-items: center;
  }

  /* ── Logo ── */
  .site-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    justify-self: center;
    gap: 1px;
  }

  .site-logo__img {
    height: 32px;
    width: auto;
    display: block;
  }



  /* ── Contact bar (desktop only) ── */
  .header-contact {
    display: none;
  }

  /* ── Actions ── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
    justify-self: end;
  }

  .header-btn {
    position: relative;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--clr-n-700);
    transition: var(--t-color);
    -webkit-tap-highlight-color: transparent;
  }
  .header-btn:hover {
    color: var(--clr-p-500);
    background: var(--clr-n-50);
  }
  :global(.header-btn:focus-visible) {
    outline: none;
    box-shadow: var(--ring-focus);
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .site-header {
      height: var(--header-h);
    }

    .header-inner {
      grid-template-columns: auto 1fr auto;
      gap: var(--sp-6);
      padding-inline: var(--gutter);
    }

    .header-left {
      display: none;
    }

    .site-logo {
      align-items: flex-start;
      justify-self: start;
    }

    .site-logo__img {
      height: 38px;
    }



    .header-contact {
      display: flex;
      align-items: center;
      gap: var(--sp-2);
      font-size: var(--text-sm);
      color: var(--text-mid);
      flex-wrap: wrap;
      justify-content: center;
    }

    .contact-sep {
      color: var(--clr-n-300);
    }

    .contact-hours {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .contact-hours {
      display: inline;
    }
  }
</style>
