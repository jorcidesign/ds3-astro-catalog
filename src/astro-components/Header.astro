---
import type { SiteData, NavItem, SubNavItem } from '../types';

interface Props {
  site: SiteData;
  currentPath?: string;
}

const { site, currentPath } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src={site.logo} alt={site.siteName} class="logo" referrerpolicy="no-referrer" />
      <span class="site-name">{site.siteName}</span>
    </a>

    <nav class="main-nav" id="main-nav" aria-label="Navegación principal">
      <ul class="nav-list">
        {site.mainNav.map((item: NavItem) => (
          <li class={`nav-item ${item.children ? 'has-children' : ''}`}>
            {item.children ? (
              <>
                <a
                  href={item.href}
                  class={`nav-link ${currentPath?.startsWith(item.href) ? 'active' : ''}`}
                >
                  {item.label}
                </a>
                <ul class="subnav">
                  {item.children.map((child: SubNavItem) => (
                    <li>
                      <a
                        href={child.href}
                        class={`subnav-link ${currentPath === child.href ? 'active' : ''}`}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={item.href}
                class={`nav-link ${currentPath === item.href ? 'active' : ''}`}
              >
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <button class="search-btn" aria-label="Buscar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Abrir menú">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mainNav = document.getElementById('main-nav');

  menuToggle?.addEventListener('click', () => {
    mainNav?.classList.toggle('is-open');
    const isOpen = mainNav?.classList.contains('is-open');
    menuToggle.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
  });
</script>

<style>
  .site-header {
    background: var(--surface-card);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-h);
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .logo {
    height: 36px;
    width: auto;
  }

  .site-name {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    color: var(--text-hi);
    font-size: var(--text-md);
  }

  .nav-list {
    display: flex;
    gap: var(--sp-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: block;
    padding: var(--sp-2) var(--sp-3);
    color: var(--text-mid);
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    border-radius: var(--radius-sm);
    transition: var(--t-color);
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-hi);
    background: var(--clr-n-100);
  }

  .subnav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--sp-2);
    min-width: 200px;
    box-shadow: var(--shadow-lg);
    list-style: none;
  }

  .has-children:hover .subnav,
  .has-children:focus-within .subnav {
    display: block;
  }

  .subnav-link {
    display: block;
    padding: var(--sp-2) var(--sp-3);
    text-decoration: none;
    color: var(--text-mid);
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
    transition: var(--t-color);
  }

  .subnav-link:hover,
  .subnav-link.active {
    background: var(--clr-n-100);
    color: var(--text-hi);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-mid);
    border-radius: var(--radius-sm);
    transition: var(--t-color);
  }

  .search-btn:hover {
    background: var(--clr-n-100);
    color: var(--text-hi);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-2);
  }

  .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-mid);
    margin: 5px 0;
    border-radius: var(--radius-full);
    transition: var(--t-all);
  }

  .menu-toggle:hover .bar {
    background: var(--text-hi);
  }

  @media (max-width: 768px) {
    .main-nav {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .main-nav.is-open {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: var(--header-h);
      left: 0;
      right: 0;
      background: var(--surface-card);
      border-bottom: 1px solid var(--border);
      padding: var(--sp-4) var(--gutter);
      z-index: var(--z-sticky);
      max-height: calc(100vh - var(--header-h));
      overflow-y: auto;
    }

    .main-nav.is-open .nav-list {
      flex-direction: column;
      width: 100%;
    }

    .main-nav.is-open .nav-link {
      padding: var(--sp-3) var(--sp-2);
    }

    .main-nav.is-open .subnav {
      position: static;
      box-shadow: none;
      border: none;
      padding-left: var(--sp-4);
      background: var(--clr-n-50);
      margin-top: var(--sp-1);
    }

    .header-actions {
      display: none;
    }
  }
</style>
