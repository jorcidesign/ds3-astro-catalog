---
import type { ProductImage } from '../types';

interface Props {
  images: ProductImage[];
  productName: string;
}

const { images, productName } = Astro.props;

const thumbnails: ProductImage[] = images.filter((img: ProductImage) => img.role !== 'main');
---

<div class="gallery" role="region" aria-label="Galería de imágenes">
  <div class="gallery-main">
    {images.map((img: ProductImage, i: number) => (
      <img
        src={img.src}
        alt={img.alt || productName}
        class={`gallery-img ${i === 0 ? 'is-active' : ''}`}
        data-index={i}
        loading={i === 0 ? 'eager' : 'lazy'}
        referrerpolicy="no-referrer"
      />
    ))}
  </div>
  {thumbnails.length > 0 && (
    <div class="gallery-thumbs" role="tablist" aria-label="Thumbnails">
      {thumbnails.map((img: ProductImage, i: number) => (
        <button
          class={`thumb-btn ${i === 0 ? 'is-active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={img.alt}
          data-index={i}
        >
          <img src={img.src} alt={img.alt} loading="lazy" referrerpolicy="no-referrer" />
        </button>
      ))}
    </div>
  )}
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .gallery-main {
    position: relative;
    background: var(--clr-n-50);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .gallery-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--sp-6);
    opacity: 0;
    transition: opacity var(--dur-200) var(--ease-out);
    pointer-events: none;
  }

  .gallery-img.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .gallery-thumbs {
    display: flex;
    gap: var(--sp-2);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .gallery-thumbs::-webkit-scrollbar {
    display: none;
  }

  .thumb-btn {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    padding: 0;
    border: 2px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    background: var(--clr-n-50);
    transition: border-color var(--dur-150);
  }

  .thumb-btn:hover {
    border-color: var(--border-strong);
  }

  .thumb-btn.is-active {
    border-color: var(--clr-p-500);
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--sp-1);
  }
</style>

<script>
  document.querySelectorAll('.gallery').forEach(gallery => {
    const mainImgs = gallery.querySelectorAll('.gallery-img');
    const thumbBtns = gallery.querySelectorAll('.thumb-btn');

    thumbBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.index || '0');
        mainImgs.forEach((img, i) => img.classList.toggle('is-active', i === idx));
        thumbBtns.forEach((b, i) => {
          b.classList.toggle('is-active', i === idx);
          b.setAttribute('aria-selected', i === idx ? 'true' : 'false');
        });
      });
    });

    gallery.querySelectorAll('.thumb-btn').forEach((btn, i) => {
      btn.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        const btns = [...gallery.querySelectorAll('.thumb-btn')] as HTMLElement[];
        if (ke.key === 'ArrowRight') {
          e.preventDefault();
          btns[(i + 1) % btns.length].focus();
        }
        if (ke.key === 'ArrowLeft') {
          e.preventDefault();
          btns[(i - 1 + btns.length) % btns.length].focus();
        }
      });
    });
  });
</script>
