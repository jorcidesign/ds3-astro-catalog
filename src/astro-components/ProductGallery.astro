---
import type { ProductImage } from '../types';

interface Props {
  images: ProductImage[];
  productName: string;
}

const { images, productName } = Astro.props;

const mainImage: ProductImage | undefined = images.find((img: ProductImage) => img.role === 'main');
const thumbnails: ProductImage[] = images.filter((img: ProductImage) => img.role !== 'main');
---

<div class="gallery">
  {mainImage && (
    <figure class="gallery-main">
      <img src={mainImage.src} alt={mainImage.alt || productName} />
    </figure>
  )}

  {thumbnails.length > 0 && (
    <div class="gallery-thumbs">
      {thumbnails.map((img: ProductImage) => (
        <button class="thumb-btn" aria-label={img.alt}>
          <img src={img.src} alt={img.alt} loading="lazy" />
        </button>
      ))}
    </div>
  )}
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .gallery-main {
    margin: 0;
    background: #f8f9fa;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.5rem;
  }

  .thumb-btn {
    width: 72px;
    height: 72px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    background: #f8f9fa;
    transition: border-color 0.2s;
  }

  .thumb-btn:hover {
    border-color: #3b82f6;
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.375rem;
  }
</style>
