---
import MainLayout from '../../../layouts/MainLayout.astro';
import ProductGallery from '../../../astro-components/ProductGallery.astro';
import ProductKeyFeatures from '../../../astro-components/ProductKeyFeatures.astro';
import ProductSpecs from '../../../astro-components/ProductSpecs.astro';
import RelatedProducts from '../../../astro-components/RelatedProducts.astro';
import QtyControl from '../../../astro-components/QtyControl.astro';
import CTAStack from '../../../astro-components/CTAStack.astro';
import Tabs from '../../../astro-components/Tabs.astro';
import FAQ from '../../../astro-components/FAQ.astro';
import { getCollection, getEntry } from 'astro:content';
import type { ProductEntry, BreadcrumbItem } from '../../../types';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p: ProductEntry) => {
    const parts = p.data.slug.split('/');
    return {
      params: { brand: parts[0], slug: parts[1] },
      props: { entryId: p.id },
    };
  });
}

const { entryId } = Astro.props;
const product = await getEntry('products', entryId);
const site = await getEntry('site', 'config');

if (!product) return Astro.redirect('/404');

const p = product.data;
const canonicalSlug = p.slug.split('/').pop();

let relatedEntries: typeof product[] = [];
if (p.relatedProducts?.length) {
  relatedEntries = (await Promise.all(p.relatedProducts.map((s: string) => getEntry('products', s)))).filter(Boolean) as typeof relatedEntries;
}

const watxt = `Hola, me interesa el producto ${p.name} (SKU: ${p.sku})`;
const datasheetUrl = p.downloads?.find((d: { type: string }) => d.type === 'datasheet')?.url;
---

<MainLayout
  title={`${p.name} | ${p.brand}`}
  description={p.shortDescription}
  site={site.data}
  breadcrumb={p.breadcrumb}
  currentPath={`/productos/${p.brand.toLowerCase()}/${canonicalSlug}`}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      {p.breadcrumb.map((crumb: BreadcrumbItem, i: number) => (
        <span class="crumb">
          {i > 0 && <span class="separator" aria-hidden="true">/</span>}
          {i < p.breadcrumb.length - 1
            ? <a href={crumb.href}>{crumb.label}</a>
            : <span aria-current="page">{crumb.label}</span>
          }
        </span>
      ))}
    </div>
  </nav>

  <div class="product-layout container">
    <div class="product-gallery-col">
      <ProductGallery images={p.images} productName={p.name} />
    </div>

    <div class="product-info-col">
      <div class="product-header">
        <span class="product-brand">{p.brand}</span>
        <h1 class="product-title">{p.name}</h1>
        <p class="product-sku">SKU: {p.sku}</p>
      </div>

      <p class="product-desc">{p.shortDescription}</p>

      <div class="price-block">
        {p.price.amount > 0 ? (
          <>
            <span class="price-amount">${p.price.amount.toFixed(2)}</span>
            <span class="price-unit">/ {p.price.unit}</span>
            {!p.price.includesIGV && <span class="price-tax">+ IGV</span>}
          </>
        ) : (
          <span class="price-consult">Consultar precio</span>
        )}
        <span class={`badge ${p.inStock ? 'badge--success' : 'badge--danger'}`}>
          {p.inStock ? 'En stock' : 'Sin stock'}
        </span>
      </div>

      {p.keyFeatures?.length && <ProductKeyFeatures features={p.keyFeatures} />}

      {p.inStock && p.price.amount > 0 && (
        <QtyControl price={p.price.amount} />
      )}

      <CTAStack
        whatsapp={site.data.contact.whatsapp}
        whatsappText={watxt}
        datasheetUrl={datasheetUrl}
      />
    </div>
  </div>

  <div class="product-tabs-section container">
    <Tabs>
      <Fragment slot="tab-desc">
        {p.longDescription?.split('\n').map((para: string) => para.trim() ? <p>{para.trim()}</p> : null)}
      </Fragment>

      <Fragment slot="tab-specs">
        {p.specTable?.length && <ProductSpecs specTable={p.specTable} />}
      </Fragment>

      <Fragment slot="tab-downloads">
        {p.downloads?.length && (
          <div class="downloads-grid">
            {p.downloads.map((dl: { label: string; url: string }) => (
              <a href={dl.url} target="_blank" rel="noopener" class="download-item">
                <svg class="dl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 15V3m0 12l-4-4m4 4l4-4M2 17l.621 2.485A2 2 0 004.561 21h14.878a2 2 0 001.94-1.515L22 17"/>
                </svg>
                <span>{dl.label}</span>
              </a>
            ))}
          </div>
        )}
      </Fragment>
    </Tabs>
  </div>

  {p.cable && (
    <div class="container">
      <FAQ items={[
        { question: '¿Cuál es la longitud del rollo?', answer: `${p.cable.rollLength} ${p.cable.rollUnit}` },
        { question: '¿Qué tipo de chaqueta tiene?', answer: p.cable.jacket },
        { question: '¿Para qué aplicaciones es recomendado?', answer: p.cable.applications.join(', ') },
      ]} />
    </div>
  )}

  <RelatedProducts products={relatedEntries.map(e => e.data)} title="Productos relacionados" />
</MainLayout>

<style>
  .breadcrumb {
    padding: var(--sp-4) 0;
    font-size: var(--text-sm);
    color: var(--text-mid);
  }

  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }

  .crumb {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .crumb a {
    color: var(--text-link);
  }

  .crumb a:hover {
    color: var(--text-link-hov);
  }

  .separator {
    color: var(--border-strong);
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr var(--product-aside-w);
    gap: var(--sp-8);
    margin-bottom: var(--sp-8);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .product-layout {
      grid-template-columns: 1fr;
    }
  }

  .product-gallery-col {
    position: sticky;
    top: calc(var(--header-h) + var(--sp-4));
  }

  @media (max-width: 1024px) {
    .product-gallery-col {
      position: static;
    }
  }

  .product-header {
    margin-bottom: var(--sp-4);
  }

  .product-brand {
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
    color: var(--text-brand);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
  }

  .product-title {
    font-size: var(--text-2xl);
    font-weight: var(--fw-bold);
    color: var(--text-hi);
    margin: var(--sp-1) 0 var(--sp-2);
    line-height: var(--lh-tight);
  }

  .product-sku {
    font-size: var(--text-sm);
    color: var(--text-low);
    margin: 0;
  }

  .product-desc {
    font-size: var(--text-base);
    color: var(--text-mid);
    line-height: var(--lh-relaxed);
    margin: 0 0 var(--sp-5);
  }

  .price-block {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }

  .price-amount {
    font-size: var(--text-3xl);
    font-weight: var(--fw-extrabold);
    color: var(--clr-success-text);
    font-family: var(--font-display);
  }

  .price-unit {
    font-size: var(--text-base);
    color: var(--text-mid);
  }

  .price-tax {
    font-size: var(--text-sm);
    color: var(--clr-error-text);
    font-weight: var(--fw-semibold);
  }

  .price-consult {
    font-size: var(--text-xl);
    font-weight: var(--fw-semibold);
    color: var(--text-brand);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--fw-semibold);
  }

  .badge--success {
    background: var(--clr-success-bg);
    color: var(--clr-success-text);
  }

  .badge--danger {
    background: var(--clr-error-bg);
    color: var(--clr-error-text);
  }

  .product-tabs-section {
    margin: var(--sp-8) 0;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--sp-3);
  }

  .download-item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-hi);
    font-size: var(--text-sm);
    font-weight: var(--fw-medium);
    transition: var(--t-color);
  }

  .download-item:hover {
    border-color: var(--border-strong);
    background: var(--clr-n-50);
  }

  .dl-icon {
    width: 20px;
    height: 20px;
    color: var(--text-brand);
    flex-shrink: 0;
  }
</style>
