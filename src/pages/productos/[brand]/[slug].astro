---
import MainLayout from '../../../layouts/MainLayout.astro';
import ProductGallery from '../../../astro-components/ProductGallery.astro';
import ProductKeyFeatures from '../../../astro-components/ProductKeyFeatures.astro';
import ProductSpecs from '../../../astro-components/ProductSpecs.astro';
import RelatedProducts from '../../../astro-components/RelatedProducts.astro';
import { getCollection, getEntry } from 'astro:content';
import type { ProductEntry, BreadcrumbItem } from '../../../types';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p: ProductEntry) => {
    const parts = p.data.slug.split('/');
    return {
      params: { brand: parts[0], slug: parts[1] },
      props: { entryId: p.id },
    };
  });
}

const { entryId } = Astro.props;
const product = await getEntry('products', entryId);
const site = await getEntry('site', 'config');

if (!product) {
  return Astro.redirect('/404');
}

const p = product.data;
const brandSlug = p.brand.toLowerCase();
const canonicalSlug = p.slug.split('/').pop();

// Load related products
let relatedEntries: typeof product[] = [];
if (p.relatedProducts && p.relatedProducts.length > 0) {
  relatedEntries = (await Promise.all(
    p.relatedProducts.map((slug: string) => getEntry('products', slug))
  )).filter((e): e is NonNullable<typeof e> => e !== undefined);
}
---

<MainLayout
  title={`${p.name} | ${p.brand}`}
  description={p.shortDescription}
  site={site.data}
  seo={p.seo}
  breadcrumb={p.breadcrumb}
  currentPath={`/productos/${brandSlug}/${canonicalSlug}`}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    {p.breadcrumb.map((crumb: BreadcrumbItem, i: number) => (
      <span class="crumb">
        {i > 0 && <span class="separator" aria-hidden="true">/</span>}
        {i < p.breadcrumb.length - 1 ? (
          <a href={crumb.href}>{crumb.label}</a>
        ) : (
          <span aria-current="page">{crumb.label}</span>
        )}
      </span>
    ))}
  </nav>

  <div class="product-layout">
    <div class="product-gallery-col">
      <ProductGallery images={p.images} productName={p.name} />
    </div>

    <div class="product-info-col">
      <div class="product-header">
        <span class="product-brand">{p.brand}</span>
        <h1 class="product-title">{p.name}</h1>
        <p class="product-sku">SKU: {p.sku}</p>
      </div>

      <div class="product-price-block">
        {p.price.amount > 0 ? (
          <>
            <span class="price-amount">${p.price.amount.toFixed(2)}</span>
            <span class="price-unit">/ {p.price.unit}</span>
            <span class="price-currency">{p.price.currency}</span>
            {!p.price.includesIGV && (
              <span class="price-tax">+ IGV</span>
            )}
          </>
        ) : (
          <span class="price-consult">Consultar precio</span>
        )}
        <span class={`stock-badge ${p.inStock ? 'in-stock' : 'out-of-stock'}`}>
          {p.inStock ? 'En stock' : 'Sin stock'}
        </span>
      </div>

      <p class="product-description">{p.shortDescription}</p>
    </div>
  </div>

  {p.keyFeatures && p.keyFeatures.length > 0 && (
    <ProductKeyFeatures features={p.keyFeatures} />
  )}

  {p.longDescription && (
    <section class="long-description">
      <h2 class="section-title">Descripción</h2>
      <div class="desc-content">
        {p.longDescription.split('\n').map((para: string) => (
          para.trim() ? <p>{para.trim()}</p> : null
        ))}
      </div>
    </section>
  )}

  {p.specTable && p.specTable.length > 0 && (
    <ProductSpecs specTable={p.specTable} />
  )}

  {p.downloads && p.downloads.length > 0 && (
    <section class="downloads">
      <h2 class="section-title">Descargas</h2>
      <div class="downloads-list">
        {p.downloads.map((dl: { label: string; url: string; type: string }) => (
          <a href={dl.url} target="_blank" rel="noopener" class="download-link">
            📄 {dl.label}
          </a>
        ))}
      </div>
    </section>
  )}

  <RelatedProducts
    products={relatedEntries.map((e) => e.data)}
    title="También disponible"
  />
</MainLayout>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 1.5rem;
    padding: 0.5rem 0;
  }

  .crumb a {
    color: #3b82f6;
    text-decoration: none;
  }

  .crumb a:hover {
    text-decoration: underline;
  }

  .separator {
    margin: 0 0.5rem;
    color: #d1d5db;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
    }
  }

  .product-brand {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #3b82f6;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .product-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .product-sku {
    font-size: 0.85rem;
    color: #9ca3af;
    margin: 0 0 1.5rem;
  }

  .product-price-block {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .price-amount {
    font-size: 2rem;
    font-weight: 800;
    color: #059669;
  }

  .price-unit {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .price-currency {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .price-tax {
    font-size: 0.8rem;
    color: #ef4444;
    font-weight: 600;
  }

  .price-consult {
    font-size: 1.125rem;
    font-weight: 600;
    color: #3b82f6;
  }

  .stock-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .in-stock {
    background: #d1fae5;
    color: #065f46;
  }

  .out-of-stock {
    background: #fee2e2;
    color: #991b1b;
  }

  .product-description {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.7;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #3b82f6;
    display: inline-block;
  }

  .long-description {
    margin: 2rem 0;
  }

  .desc-content p {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .downloads {
    margin: 2rem 0;
  }

  .downloads-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .download-link {
    display: inline-block;
    padding: 0.625rem 1rem;
    background: #f0f4f8;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    text-decoration: none;
    color: #374151;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .download-link:hover {
    background: #e4eaf0;
  }
</style>
