---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductCard from '../../astro-components/ProductCard.astro';
import { getEntry, getCollection } from 'astro:content';
import type { ProductEntry } from '../../types';

const site = await getEntry('site', 'config');
const products = await getCollection('products');
---

<MainLayout
  title="Productos"
  description="Catálogo completo de productos de infraestructura de redes y telecomunicaciones"
  site={site.data}
  currentPath="/productos"
>
  <section class="page-header">
    <h1>Productos</h1>
    <p>{products.length} producto(s) disponible(s)</p>
  </section>

  <div class="product-grid">
    {products.map((p: ProductEntry) => (
      <ProductCard product={p.data} />
    ))}
  </div>
</MainLayout>

<style>
  .page-header {
    padding: 1rem 0 2rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #111827;
    margin: 0 0 0.5rem;
  }

  .page-header p {
    color: #6b7280;
    margin: 0;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding-bottom: 3rem;
  }
</style>
