---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../astro-components/ProductCard.astro';
import TrustBar from '../astro-components/TrustBar.astro';
import { getEntry, getCollection } from 'astro:content';
import type { BrandEntry, ProductEntry } from '../types';

const site = await getEntry('site', 'config');
const products = await getCollection('products');
const featuredProducts = products.slice(0, 3);
---

<MainLayout
  title="Inicio"
  description={site.data.tagline}
  site={site.data}
  currentPath="/"
  showTrustBar={false}
>
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">{site.data.siteName}</h1>
      <p class="hero-tagline">{site.data.tagline}</p>
    </div>
  </section>

  <section class="brands-section section">
    <div class="container">
      <h2 class="section-title">Nuestras marcas</h2>
      <div class="brand-grid">
        {site.data.brands.map((b: BrandEntry) => (
          <a href={b.href} class="brand-card">
            <img src={b.logo} alt={b.name} loading="lazy" referrerpolicy="no-referrer" />
            <span class="brand-name">{b.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <TrustBar />

  <section class="featured-section section">
    <div class="container">
      <h2 class="section-title">Productos destacados</h2>
      <div class="product-grid">
        {featuredProducts.map((p: ProductEntry) => (
          <ProductCard product={p.data} />
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    text-align: center;
    padding: var(--sp-12) 0 var(--sp-8);
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: var(--fw-extrabold);
    color: var(--text-hi);
    margin: 0 0 var(--sp-3);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--text-mid);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--lh-relaxed);
  }

  .section {
    padding: var(--sp-8) 0;
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: var(--fw-bold);
    color: var(--text-hi);
    margin: 0 0 var(--sp-6);
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--sp-4);
  }

  .brand-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-5);
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: var(--t-shadow), var(--t-transform);
  }

  .brand-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .brand-card img {
    max-height: 32px;
    width: auto;
    object-fit: contain;
  }

  .brand-name {
    font-size: var(--text-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-mid);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-5);
  }
</style>
